<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111827">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎤 VoiceCapture"
            android:textSize="22sp"
            android:textColor="#F9FAFB"
            android:fontFamily="sans-serif-black"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Letzte Aufnahmen"
            android:textSize="13sp"
            android:textColor="#6B7280"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:id="@+id/empty_state"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="60dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Noch keine Aufnahmen"
                android:textColor="#6B7280"
                android:textSize="16sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tippe auf das Mikrofon um zu starten"
                android:textColor="#4B5563"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_recent"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="80dp" />

    </LinearLayout>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_suggestions"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:text="💡"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:background="@drawable/chip_bg"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="76dp"
        android:layout_marginEnd="88dp" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_record"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="72dp"
        android:layout_marginEnd="16dp"
        android:src="@drawable/ic_mic"
        app:backgroundTint="#EF4444"
        app:tint="#FFFFFF"
        xmlns:app="http://schemas.android.com/apk/res-auto" />

</FrameLayout>
