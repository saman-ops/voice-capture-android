<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- Header: nur Status-Info, keine Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="14dp"
        android:paddingBottom="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔴"
            android:textSize="14sp"
            android:layout_marginEnd="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LIVE"
            android:textColor="@color/accent_voice"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.1" />

        <TextView
            android:id="@+id/tv_timer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="00:00"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:fontFamily="sans-serif"
            android:gravity="end" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border" />

    <!-- Summarization progress -->
    <ProgressBar
        android:id="@+id/progress_summarizing"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:indeterminate="true"
        android:indeterminateTint="@color/accent_voice"
        android:visibility="gone"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal" />

    <!-- Transcript / Summary area -->
    <ScrollView
        android:id="@+id/scroll_transcript"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <TextView
            android:id="@+id/tv_transcript"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.5"
            android:hint="Sprechen Sie... Transkription erscheint hier."
            android:textColorHint="@color/text_muted" />

    </ScrollView>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border" />

    <!-- ACTION ITEMS section -->
    <LinearLayout
        android:id="@+id/action_items_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground">

        <TextView
            android:id="@+id/tv_action_items_toggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="▼"
            android:textColor="@color/text_muted"
            android:textSize="10sp"
            android:layout_marginEnd="6dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="ACTION ITEMS"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.08" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_tasks_all"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:text="📋"
            android:textSize="14sp"
            android:background="@android:color/transparent"
            android:padding="0dp"
            android:layout_marginEnd="4dp"
            android:contentDescription="Alle an Google Tasks senden" />

        <ImageButton
            android:id="@+id/btn_add_action_item"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_input_add"
            android:background="@android:color/transparent"
            android:tint="@color/accent_voice_light"
            android:contentDescription="Action Item hinzufügen" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_action_items"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:nestedScrollingEnabled="true"
        android:overScrollMode="never"
        android:clipToPadding="false"
        android:paddingBottom="4dp" />

    <TextView
        android:id="@+id/tv_action_items_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Noch keine Action Items erkannt"
        android:textColor="@color/text_muted"
        android:textSize="12sp"
        android:fontFamily="sans-serif"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="6dp"
        android:paddingBottom="10dp"
        android:visibility="gone" />

    <!-- Advisor Panel — 3 autonome Agenten -->
    <LinearLayout
        android:id="@+id/advisor_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- PM Coach card (grün) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_pm_coach"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="2dp"
            app:cardBackgroundColor="@color/surface_pm_coach"
            app:cardCornerRadius="8dp"
            app:strokeColor="@color/stroke_pm_coach"
            app:strokeWidth="1dp"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="6dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="4dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎯"
                        android:textSize="13sp"
                        android:layout_marginEnd="8dp" />
                    <TextView
                        android:id="@+id/tv_pm_coach"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/text_pm_coach"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.2" />
                    <ImageButton
                        android:id="@+id/btn_dismiss_pm_coach"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:padding="8dp"
                        android:scaleType="fitCenter"
                        android:src="@android:drawable/ic_menu_close_clear_cancel"
                        android:background="@android:color/transparent"
                        android:tint="@color/text_muted"
                        android:contentDescription="Schließen" />
                </LinearLayout>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tippen → Als Action Item"
                    android:textColor="@color/hint_pm_coach"
                    android:textSize="9sp"
                    android:paddingStart="12dp"
                    android:paddingBottom="6dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Workflow Manager card (blau) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_workflow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="2dp"
            app:cardBackgroundColor="@color/surface_workflow"
            app:cardCornerRadius="8dp"
            app:strokeColor="@color/stroke_workflow"
            app:strokeWidth="1dp"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="6dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="4dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚙️"
                        android:textSize="13sp"
                        android:layout_marginEnd="8dp" />
                    <TextView
                        android:id="@+id/tv_workflow"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/text_workflow"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.2" />
                    <ImageButton
                        android:id="@+id/btn_dismiss_workflow"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:padding="8dp"
                        android:scaleType="fitCenter"
                        android:src="@android:drawable/ic_menu_close_clear_cancel"
                        android:background="@android:color/transparent"
                        android:tint="@color/text_muted"
                        android:contentDescription="Schließen" />
                </LinearLayout>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tippen → Als Action Item"
                    android:textColor="@color/stroke_workflow"
                    android:textSize="9sp"
                    android:paddingStart="12dp"
                    android:paddingBottom="6dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Strategischer Berater card (rot) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_berater"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="6dp"
            app:cardBackgroundColor="@color/surface_berater"
            app:cardCornerRadius="8dp"
            app:strokeColor="@color/stroke_berater"
            app:strokeWidth="1dp"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="6dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="4dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💡"
                        android:textSize="13sp"
                        android:layout_marginEnd="8dp" />
                    <TextView
                        android:id="@+id/tv_berater"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/text_berater"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.2" />
                    <ImageButton
                        android:id="@+id/btn_dismiss_berater"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:padding="8dp"
                        android:scaleType="fitCenter"
                        android:src="@android:drawable/ic_menu_close_clear_cancel"
                        android:background="@android:color/transparent"
                        android:tint="@color/text_muted"
                        android:contentDescription="Schließen" />
                </LinearLayout>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tippen → Als Action Item"
                    android:textColor="@color/stroke_berater"
                    android:textSize="9sp"
                    android:paddingStart="12dp"
                    android:paddingBottom="6dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border" />

    <!-- Untere Steuerleiste — alle interaktiven Buttons unten für Daumen-Erreichbarkeit -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="16dp"
        android:background="@color/bg_dark">

        <!-- Mode Chips -->
        <HorizontalScrollView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:scrollbars="none">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/mode_chips"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_original"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Original"
                    android:textColor="@color/text_secondary"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    app:chipBackgroundColor="@color/surface"
                    app:chipStrokeColor="@color/border"
                    app:chipStrokeWidth="1dp"
                    android:checked="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_simple"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Einfach"
                    android:textColor="@color/text_secondary"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    app:chipBackgroundColor="@color/surface"
                    app:chipStrokeColor="@color/border"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_deep"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tief"
                    android:textColor="@color/text_secondary"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    app:chipBackgroundColor="@color/surface"
                    app:chipStrokeColor="@color/border"
                    app:chipStrokeWidth="1dp" />

            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>

        <!-- ⚡ Jetzt — nur in Einfach/Tief Modus sichtbar -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_summarize_now"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="⚡"
            android:textSize="14sp"
            android:background="@drawable/chip_bg"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginStart="6dp"
            android:visibility="gone" />

        <!-- Advisor Panel Toggle -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_coach_toggle"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="👥"
            android:textSize="14sp"
            android:background="@drawable/chip_bg"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginStart="6dp"
            android:alpha="1.0" />

        <!-- Stop -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_stop_live"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="■ Stop"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/chip_bg"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginStart="6dp" />

    </LinearLayout>

</LinearLayout>
