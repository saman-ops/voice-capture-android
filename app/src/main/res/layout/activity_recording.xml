<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0F172A"
    android:gravity="center">

    <TextView
        android:id="@+id/tv_idle_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tippen zum Aufnehmen"
        android:textColor="#6B7280"
        android:textSize="16sp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tv_timer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:00"
        android:textSize="56sp"
        android:textColor="#F9FAFB"
        android:fontFamily="sans-serif-light"
        android:visibility="gone"
        android:layout_marginBottom="16dp" />

    <com.s3id3l.voicecapture.ui.recording.WaveformView
        android:id="@+id/waveform_view"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:visibility="gone"
        android:layout_marginBottom="24dp"
        android:layout_marginLeft="24dp"
        android:layout_marginRight="24dp" />

    <LinearLayout
        android:id="@+id/processing_group"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        android:layout_marginBottom="16dp">

        <ProgressBar
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:indeterminate="true"
            android:indeterminateTint="#EF4444" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Wird verarbeitet…"
            android:textColor="#9CA3AF"
            android:textSize="14sp"
            android:layout_marginTop="8dp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/result_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        android:paddingLeft="24dp"
        android:paddingRight="24dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✅ Fertig!"
            android:textColor="#10B981"
            android:textSize="20sp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tv_result_preview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#D1D5DB"
            android:textSize="13sp"
            android:background="@drawable/input_bg"
            android:padding="12dp"
            android:maxLines="5"
            android:ellipsize="end"
            android:layout_marginBottom="16dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_open_detail"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Details öffnen →"
            android:background="@drawable/btn_record_bg"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

    </LinearLayout>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_record"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:text="🎤"
        android:textSize="40sp"
        android:background="@drawable/btn_record_bg"
        android:textColor="#FFFFFF" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_cancel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Abbrechen"
        android:textColor="#6B7280"
        android:background="@null"
        android:layout_marginTop="16dp" />

</LinearLayout>
