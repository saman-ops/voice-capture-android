<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Format selector — visible in idle state only -->
    <LinearLayout
        android:id="@+id/format_select_group"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:visibility="visible"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FORMAT"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp" />

        <HorizontalScrollView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/format_chips_record"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                android:paddingStart="20dp"
                android:paddingEnd="20dp" />

        </HorizontalScrollView>

    </LinearLayout>

    <!-- IDLE state: subtle hint above record button -->
    <TextView
        android:id="@+id/tv_idle_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tippen zum Aufnehmen"
        android:textColor="@color/text_secondary"
        android:textSize="15sp"
        android:fontFamily="sans-serif"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/format_select_group"
        app:layout_constraintBottom_toTopOf="@id/btn_record"
        android:layout_marginBottom="56dp" />

    <!-- RECORDING state: large mono timer -->
    <TextView
        android:id="@+id/tv_timer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:00"
        android:textSize="72sp"
        android:textColor="@color/text_primary"
        android:fontFamily="sans-serif-light"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/waveform_view"
        android:layout_marginBottom="8dp" />

    <!-- RECORDING state: live waveform just above button -->
    <com.s3id3l.voicecapture.ui.recording.WaveformView
        android:id="@+id/waveform_view"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:visibility="gone"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="36dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btn_record" />

    <!-- PROCESSING state: spinner + label -->
    <LinearLayout
        android:id="@+id/processing_group"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btn_record">

        <ProgressBar
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:indeterminate="true"
            android:indeterminateTint="@color/accent_voice" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Wird verarbeitet …"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginTop="16dp" />

    </LinearLayout>

    <!-- RESULT state: preview card + CTA -->
    <LinearLayout
        android:id="@+id/result_group"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btn_record">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fertig"
            android:textColor="@color/accent_green"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tv_result_preview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.3"
            android:background="@drawable/input_bg"
            android:padding="12dp"
            android:maxLines="4"
            android:ellipsize="end"
            android:layout_marginBottom="12dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_open_detail"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Details anzeigen"
            android:background="@drawable/btn_primary_bg"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium" />

    </LinearLayout>

    <!-- Record / Stop button — circular, fixed vertical position -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_record"
        android:layout_width="88dp"
        android:layout_height="88dp"
        android:text=""
        android:textSize="36sp"
        android:textColor="@color/text_primary"
        android:background="@drawable/btn_record_bg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.50" />

    <!-- Cancel text link below record button -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_cancel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Abbrechen"
        android:textColor="@color/text_muted"
        android:textSize="14sp"
        android:background="@null"
        android:paddingTop="20dp"
        android:paddingBottom="20dp"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="24dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
