<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Verlauf"
        android:textSize="26sp"
        android:textColor="@color/text_primary"
        android:fontFamily="sans-serif-black"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="28dp"
        android:paddingBottom="16dp" />

    <!-- Filter chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_marginBottom="12dp">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/filter_chips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true" />

    </HorizontalScrollView>

    <!-- Empty state -->
    <TextView
        android:id="@+id/empty_history"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Keine Aufnahmen vorhanden"
        android:textColor="@color/text_secondary"
        android:textSize="15sp"
        android:gravity="center"
        android:paddingTop="72dp"
        android:paddingBottom="72dp"
        android:visibility="gone" />

    <!-- History list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_history"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false" />

    <!-- Multi-select action bar -->
    <LinearLayout
        android:id="@+id/multi_select_bar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/surface"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_selection_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_multi_chat"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="Mit KI besprechen"
            android:textColor="@color/text_primary"
            android:background="@drawable/btn_primary_bg"
            android:textSize="13sp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginEnd="8dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_cancel_selection"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="✕"
            android:textColor="@color/text_muted"
            android:background="@null"
            android:textSize="18sp" />

    </LinearLayout>

</LinearLayout>
