<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1F2937"
    android:minHeight="480dp">

    <TextView
        android:id="@+id/tv_context_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#9CA3AF"
        android:textSize="12sp"
        android:padding="16dp"
        android:paddingBottom="4dp"
        android:fontFamily="sans-serif-medium" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#374151"
        android:layout_marginBottom="4dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_chat"
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:padding="8dp"
        android:clipToPadding="false" />

    <ProgressBar
        android:id="@+id/progress_chat"
        android:layout_width="wrap_content"
        android:layout_height="24dp"
        android:layout_gravity="center_horizontal"
        android:indeterminate="true"
        android:indeterminateTint="#6366F1"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Frage zu allen Aufnahmen…"
            android:textColorHint="#4B5563"
            android:textColor="#F9FAFB"
            android:background="@drawable/input_bg"
            android:padding="10dp"
            android:inputType="textMultiLine|textCapSentences"
            android:maxLines="3"
            android:layout_marginEnd="8dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_send"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="→"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/btn_record_bg" />

    </LinearLayout>

</LinearLayout>
