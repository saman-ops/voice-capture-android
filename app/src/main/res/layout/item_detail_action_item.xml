<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="4dp"
    android:paddingEnd="0dp"
    android:paddingTop="5dp"
    android:paddingBottom="5dp">

    <TextView
        android:id="@+id/tv_detail_action_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="☐"
        android:textSize="16sp"
        android:textColor="@color/text_muted"
        android:layout_marginEnd="8dp" />

    <TextView
        android:id="@+id/tv_detail_action_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textColor="@color/accent_teal"
        android:textSize="13sp"
        android:lineSpacingMultiplier="1.4" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_detail_send_tasks"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:minWidth="0dp"
        android:text="📋 Senden"
        android:textSize="11sp"
        android:textColor="@color/accent_voice"
        android:background="@drawable/chip_bg"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:contentDescription="An Google Tasks senden" />

</LinearLayout>
